{
  "info": {
    "name": "CKO2 Payment Gateway",
    "description": "Payment Gateway API - Code Challenge",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7092"
    },
    {
      "key": "paymentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "POST - Authorized (odd digit)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Payment is Authorized', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql('Authorized');",
              "    pm.expect(body.cardNumberLastFour).to.eql(8877);",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('paymentId', body.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"cardNumber\": \"2222405343248877\",\n  \"expiryMonth\": 4,\n  \"expiryYear\": 2027,\n  \"currency\": \"GBP\",\n  \"amount\": 100,\n  \"cvv\": \"123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Payments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Payments"]
        }
      }
    },
    {
      "name": "POST - Declined (even digit)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Payment is Declined', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.status).to.eql('Declined');",
