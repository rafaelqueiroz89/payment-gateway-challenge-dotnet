    },
    {
      "name": "GET - Retrieve payment",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Has masked card number', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body.cardNumberLastFour).to.be.a('number');",
              "    pm.expect(body.id).to.eql(pm.collectionVariables.get('paymentId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Payments/{{paymentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Payments", "{{paymentId}}"]
        }
      }
    },
    {
      "name": "GET - Payment not found (404)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 404', () => pm.response.to.have.status(404));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/Payments/00000000-0000-0000-0000-000000000000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Payments", "00000000-0000-0000-0000-000000000000"]
