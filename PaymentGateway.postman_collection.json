        "body": {
          "mode": "raw",
          "raw": "{\n  \"cardNumber\": \"2222405343248878\",\n  \"expiryMonth\": 4,\n  \"expiryYear\": 2027,\n  \"currency\": \"EUR\",\n  \"amount\": 500,\n  \"cvv\": \"456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Payments",
          "host": ["{{baseUrl}}"],
          "path": ["api", "Payments"]
        }
      }
    },
